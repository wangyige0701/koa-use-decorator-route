{
	"name": "koa-use-decorator-route",
	"version": "0.0.1",
	"description": "基于 koa 和 @koa/router 的装饰器路由中间件 / A Koa plugin for @koa/router that allows you to use decorators to define routes",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		}
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rollup -c",
		"test": "vitest",
		"push": "pnpm run build && npm publish --access=public"
	},
	"keywords": [
		"koa",
		"route",
		"router",
		"@koa/route",
		"decorator"
	],
	"author": "Yige Wang <wyg1776686515@gmail.com>",
	"homepage": "https://github.com/wangyige0701/koa-use-decorator-route",
	"repository": {
		"type": "git",
		"url": "https://github.com/wangyige0701/koa-use-decorator-route.git"
	},
	"license": "MIT",
	"devDependencies": {
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@types/koa": "^3.0.2",
		"@types/node": "^25.5.0",
		"@types/supertest": "^7.2.0",
		"prettier": "^3.8.1",
		"rollup": "^4.59.1",
		"rollup-plugin-delete": "^3.0.2",
		"rollup-plugin-dts": "^6.4.1",
		"rollup-plugin-esbuild": "^6.2.1",
		"rollup-plugin-typescript2": "^0.36.0",
		"supertest": "^7.2.2",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@koa/router": "^15.4.0",
		"koa": "^3.1.2",
		"reflect-metadata": "^0.2.2"
	},
	"peerDependencies": {
		"koa": ">=2.0.0",
		"@koa/router": ">=8.0.0",
		"reflect-metadata": "^0.2.0"
	},
	"packageManager": "pnpm@9.1.0"
}
